# ── Discord ──
# Token du bot (Discord Developer Portal > Bot > Reset Token)
DISCORD_BOT_TOKEN=
# Application ID (Developer Portal > General Information > Application ID)
DISCORD_CLIENT_ID=
# (Optionnel) ID du serveur pour enregistrer les commandes instantanément en dev.
# Laisser vide pour un déploiement global (peut prendre jusqu'à 1h à propager).
DISCORD_GUILD_ID=

# ── Party-cipate API (pm-api) ──
# Base de l'API, suffixe /api inclus.
# Prod : https://api.montdescartes.fr/api   |   Local : http://localhost:3000/api
PM_API_URL=https://api.montdescartes.fr/api
# Clé partagée — DOIT être identique à BOT_API_KEY côté pm-api.
BOT_API_KEY=

# ── Notifications par MP (bouton « Notifier par MP » de /modifier-event) ──
# Liste blanche des destinataires réellement notifiés (identifiant Discord ou nom
# d'utilisateur, séparés par des virgules). Par défaut « * » : AUCUNE restriction,
# les MP partent à tous les membres des serveurs connectés à la production.
# Pour re-restreindre (ex. phase de test), mettre p. ex. NOTIFY_ALLOWLIST=nonoice.
NOTIFY_ALLOWLIST=*
